# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# API Keys (Get your free API keys from the respective services)
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# News API: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# CoinGecko (no key required for basic tier)
# COINGECKO_API_KEY=your_coingecko_key_here  # Optional for premium

# Databricks Configuration (for production deployment)
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_token_here

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=market-intelligence

# Database
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# AWS (Optional - for S3 storage)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_DEFAULT_REGION=us-east-1

# Azure (Optional)
# AZURE_STORAGE_CONNECTION_STRING=your_connection_string

# Model Serving
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Data Storage Paths
DATA_RAW_PATH=/opt/airflow/data/raw
DATA_PROCESSED_PATH=/opt/airflow/data/processed
DATA_FEATURES_PATH=/opt/airflow/data/features
MODELS_PATH=/opt/airflow/models

# Logging
LOG_LEVEL=INFO
