# =============================================================================
# Google Cloud Platform Environment Configuration
# Copy this to .env.gcp and fill in your values
#
# Usage with deploy script:
#   source .env.gcp && ./scripts/deploy-gcp.sh deploy
# =============================================================================

# Google Cloud Project Settings
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Cloud SQL Connection
CLOUD_SQL_INSTANCE=market-intel-db
CLOUD_SQL_CONNECTION=${GCP_PROJECT_ID}:${GCP_REGION}:${CLOUD_SQL_INSTANCE}

# Database connection strings (used by Cloud Run services via Cloud SQL Proxy)
AIRFLOW_DB_CONN=postgresql+psycopg2://postgres:postgres@/airflow?host=/cloudsql/${CLOUD_SQL_CONNECTION}
MLFLOW_DB_CONN=postgresql+psycopg2://postgres:postgres@/mlflow?host=/cloudsql/${CLOUD_SQL_CONNECTION}

# Airflow Configuration
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=${AIRFLOW_DB_CONN}
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin

# MLflow Configuration
MLFLOW_BACKEND_URI=${MLFLOW_DB_CONN}
MLFLOW_ARTIFACT_ROOT=gs://${GCP_PROJECT_ID}-ml-artifacts
# Set after MLflow is deployed:
# MLFLOW_TRACKING_URI=https://market-intel-mlflow-xxxxx-uc.a.run.app

# API Keys (store these in Secret Manager for production)
# Use: gcloud secrets create alpha-vantage-key --data-file=- <<< "your-key"
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
NEWS_API_KEY=your-news-api-key

# Redis (Memorystore) - optional, for feature caching
# REDIS_HOST=10.0.0.3
# REDIS_PORT=6379
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Optional: Slack notifications for alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
